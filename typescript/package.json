{
  "name": "@dvsa/page-crawler",
  "version": "1.0.0",
  "description": "AI-Augmented Accessibility Framework - crawls pages with Playwright or Selenium, runs axe-core audits, and generates GOV.UK Design System compliant fix reports via AWS Bedrock. TypeScript port of the Java PageCrawler.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test dist/__tests__/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "accessibility",
    "axe-core",
    "wcag",
    "gov.uk",
    "gds",
    "playwright",
    "selenium",
    "crawler",
    "bedrock"
  ],
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.600.0",
    "@axe-core/playwright": "^4.10.0",
    "@axe-core/webdriverjs": "^4.10.0",
    "@faker-js/faker": "^9.0.0",
    "axe-core": "^4.10.0",
    "cheerio": "^1.0.0",
    "playwright": "^1.45.0",
    "selenium-webdriver": "^4.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/selenium-webdriver": "^4.1.24",
    "typescript": "^5.5.0"
  }
}
